import Layout from '../layouts/Layout.astro';
const craft = await Astro.glob('../content/craft/*.md');
const data = [
	{name: "Instagram", title:"safar19x", link:"https://www.instagram.com/safar19x/"},
    {name: "Github", title:"safarrr" , link:"https://github.com/safarrr", icon:`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>` },
    {name: "Linkedin", title:"safarudin19 / safarudin" , link:"https://www.linkedin.com/in/safarudin19/"},
    {name: "Email", title:"safar190305@gmail.com" , link:"mailto:safar190305@gmail.com?subject=(texthere)-fromWeb"},
]
---

<Layout title="safarudin">
	<div class="w-full mx-auto space-y-4 px-5 py-2 md:max-w-2xl">
	<section class="w-full space-y-2"> 
		<div>
			<h1 class="font-extrabold text-3xl">SAFARUDIN</h1>
			<p class="text-sm">Front-End Web Developer from Indonesia. Focus on UI development. keep it simple and clean</p> 	
		</div>
		<div class="inline-flex items-center gap-2">
			<a href="https://github.com/safarrr" target="_blank" rel="noopener noreferrer" class="transition-transform ease-linear hover:scale-110" ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg></a>
			<a href="https://www.instagram.com/safar19x/" target="_blank" rel="noopener noreferrer" class="transition-transform ease-linear hover:scale-110" ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg></a>
			<a href="https://twitter.com/justsafarr" target="_blank" rel="noopener noreferrer" class="transition-transform ease-linear hover:scale-110" > <svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" fill="none" viewBox="0 0 24 25" class=" fill-black dark:fill-white">
				<g clip-path="url(#a)">
				  <path d="M14.283 10.386 23.218 0H21.1l-7.758 9.018L7.147 0H0l9.37 13.636L0 24.527h2.117l8.193-9.523 6.543 9.523H24l-9.717-14.141Zm-2.9 3.37-.95-1.357L2.88 1.594h3.252l6.096 8.72.95 1.358 7.924 11.334h-3.253l-6.466-9.249Z" />
				</g>
				<defs>
				  <clipPath id="a">
					<path  d="M0 0h24v24.54H0z"/>
				  </clipPath>
				</defs>
			  </svg>
			  </a>
			<a href="https://www.linkedin.com/in/safarudin19/" target="_blank" rel="noopener noreferrer" class="transition-transform ease-linear hover:scale-110" ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg></a>
			<a href="mailto:safar190305@gmail.com?subject=(texthere)-safarudin.my.id" target="_blank" rel="noopener noreferrer" class="transition-transform ease-linear hover:scale-110" ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-at-sign"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-4 8"/></svg></a>
		</div>
	</section>
	<section class="w-full bg-neutral-100 dark:bg-neutral-800  p-3 rounded-lg">
		<h1 class="font-bold text-xl uppercase">Craft</h1>
		<div class="flex items-center flex-wrap justify-start gap-2">
			{craft.map(v=>{
			return <a  href={v.frontmatter.link} class="hover:text-blue-500 hover:underline">
                {v.frontmatter.title}
